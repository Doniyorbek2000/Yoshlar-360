{
  "name": "yoshlar-360",
  "version": "1.0.0",
  "description": "Yoshlar 360 - O'zbekiston yoshlar bilan ishlash platformasi",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:api": "turbo run dev --filter=yoshlar-360-backend",
    "dev:web": "turbo run dev --filter=yoshlar-360-web",
    "dev:bot": "turbo run dev --filter=yoshlar-360-bot",
    "build": "turbo run build",
    "lint": "turbo run lint --parallel",
    "db:migrate": "cd apps/backend && npx prisma migrate dev",
    "db:generate": "cd apps/backend && npx prisma generate",
    "db:seed": "cd apps/backend && npx ts-node prisma/seed.ts",
    "db:studio": "cd apps/backend && npx prisma studio",
    "db:reset": "cd apps/backend && npx prisma migrate reset --force",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "clean": "rm -rf node_modules apps/*/node_modules apps/*/.next apps/*/dist"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^20.10.6",
    "prettier": "^3.1.1",
    "turbo": "^1.11.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "Yoshlar-360 Team",
  "license": "PROPRIETARY"
}
