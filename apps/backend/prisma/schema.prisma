generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  REPUBLIC_ADMIN
  REGION_ADMIN
  DISTRICT_ADMIN
  MAHALLA_LEADER
  YOUTH
  MODERATOR
}

enum Gender {
  MALE
  FEMALE
}

enum AppealStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  REJECTED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum ProblemStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EducationLevel {
  NONE
  SECONDARY
  VOCATIONAL
  HIGHER
  MASTERS
  PHD
}

enum EmploymentStatus {
  EMPLOYED
  UNEMPLOYED
  STUDENT
  SELF_EMPLOYED
  OTHER
}

enum SocialStatus {
  NORMAL
  ORPHAN
  DISABLED
  LOW_INCOME
  SINGLE_PARENT
  OTHER
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum NotificationType {
  SYSTEM
  APPEAL
  TASK
  KPI
  BROADCAST
  EVENT
  SURVEY
}

enum EventStatus {
  DRAFT
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum EventType {
  SEMINAR
  WORKSHOP
  CONFERENCE
  SPORT
  CULTURAL
  VOLUNTEERING
  OTHER
}

enum QuestionType {
  TEXT
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  RATING
  NUMBER
}

enum SurveyStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum FileCategory {
  DOCUMENT
  IMAGE
  VIDEO
  REPORT
  IMPORT
  OTHER
}

enum SmsStatus {
  PENDING
  SENT
  FAILED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

model Region {
  id        Int        @id @default(autoincrement())
  nameUz    String
  nameRu    String
  districts District[]
  users     User[]
  appeals   Appeal[]
  problems  Problem[]
  kpiRecords KpiRecord[]
  reports   Report[]
  events    Event[]
  surveys   Survey[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("regions")
}

model District {
  id        Int       @id @default(autoincrement())
  nameUz    String
  nameRu    String
  regionId  Int
  region    Region    @relation(fields: [regionId], references: [id])
  mahallas  Mahalla[]
  users     User[]
  appeals   Appeal[]
  problems  Problem[]
  kpiRecords KpiRecord[]
  reports   Report[]
  events    Event[]
  surveys   Survey[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("districts")
}

model Mahalla {
  id         Int       @id @default(autoincrement())
  nameUz     String
  nameRu     String
  districtId Int
  district   District  @relation(fields: [districtId], references: [id])
  users      User[]
  appeals    Appeal[]
  problems   Problem[]
  kpiRecords KpiRecord[]
  reports    Report[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("mahallas")
}

model User {
  id           Int       @id @default(autoincrement())
  fullName     String
  phone        String?   @unique
  email        String    @unique
  passwordHash String
  role         Role      @default(YOUTH)
  regionId     Int?
  region       Region?   @relation(fields: [regionId], references: [id])
  districtId   Int?
  district     District? @relation(fields: [districtId], references: [id])
  mahallaId    Int?
  mahalla      Mahalla?  @relation(fields: [mahallaId], references: [id])
  telegramId   String?   @unique
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  youthProfile    YouthProfile?
  createdAppeals  Appeal[]       @relation("AppealCreator")
  assignedAppeals Appeal[]       @relation("AppealAssignee")
  createdProblems Problem[]      @relation("ProblemCreator")
  assignedProblems Problem[]     @relation("ProblemAssignee")
  createdTasks    Task[]         @relation("TaskCreator")
  assignedTasks   Task[]         @relation("TaskAssignee")
  kpiRecords      KpiRecord[]
  reports         Report[]
  notifications   Notification[]
  importJobs      ImportJob[]
  auditLogs       AuditLog[]
  refreshTokens   RefreshToken[]
  appealComments  AppealComment[]
  organizedEvents    Event[]            @relation("EventOrganizer")
  eventParticipations EventParticipant[]
  createdSurveys     Survey[]           @relation("SurveyCreator")
  surveyResponses    SurveyResponse[]
  uploadedFiles      FileRecord[]       @relation("FileUploader")

  @@map("users")
}

model YouthProfile {
  id               Int              @id @default(autoincrement())
  userId           Int              @unique
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  birthDate        DateTime?
  gender           Gender?
  passportOrPinfl  String?
  education        EducationLevel?
  employmentStatus EmploymentStatus?
  socialStatus     SocialStatus?
  address          String?
  interests        String?
  riskLevel        RiskLevel        @default(LOW)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@map("youth_profiles")
}

model Appeal {
  id           Int          @id @default(autoincrement())
  title        String
  description  String
  category     String
  status       AppealStatus @default(NEW)
  priority     Priority     @default(MEDIUM)
  youthId      Int
  youth        User         @relation("AppealCreator", fields: [youthId], references: [id])
  assignedToId Int?
  assignedTo   User?        @relation("AppealAssignee", fields: [assignedToId], references: [id])
  regionId     Int?
  region       Region?      @relation(fields: [regionId], references: [id])
  districtId   Int?
  district     District?    @relation(fields: [districtId], references: [id])
  mahallaId    Int?
  mahalla      Mahalla?     @relation(fields: [mahallaId], references: [id])
  comments     AppealComment[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("appeals")
}

model AppealComment {
  id        Int      @id @default(autoincrement())
  appealId  Int
  appeal    Appeal   @relation(fields: [appealId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  text      String
  createdAt DateTime @default(now())

  @@map("appeal_comments")
}

model Problem {
  id           Int           @id @default(autoincrement())
  title        String
  description  String
  category     String
  status       ProblemStatus @default(OPEN)
  priority     Priority      @default(MEDIUM)
  regionId     Int?
  region       Region?       @relation(fields: [regionId], references: [id])
  districtId   Int?
  district     District?     @relation(fields: [districtId], references: [id])
  mahallaId    Int?
  mahalla      Mahalla?      @relation(fields: [mahallaId], references: [id])
  createdById  Int
  createdBy    User          @relation("ProblemCreator", fields: [createdById], references: [id])
  assignedToId Int?
  assignedTo   User?         @relation("ProblemAssignee", fields: [assignedToId], references: [id])
  deadline     DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("problems")
}

model Task {
  id           Int        @id @default(autoincrement())
  title        String
  description  String?
  status       TaskStatus @default(TODO)
  priority     Priority   @default(MEDIUM)
  assignedToId Int?
  assignedTo   User?      @relation("TaskAssignee", fields: [assignedToId], references: [id])
  createdById  Int
  createdBy    User       @relation("TaskCreator", fields: [createdById], references: [id])
  deadline     DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("tasks")
}

model KpiRecord {
  id         Int       @id @default(autoincrement())
  userId     Int?
  user       User?     @relation(fields: [userId], references: [id])
  regionId   Int?
  region     Region?   @relation(fields: [regionId], references: [id])
  districtId Int?
  district   District? @relation(fields: [districtId], references: [id])
  mahallaId  Int?
  mahalla    Mahalla?  @relation(fields: [mahallaId], references: [id])
  metric     String
  value      Float
  period     String
  createdAt  DateTime  @default(now())

  @@map("kpi_records")
}

model Report {
  id          Int       @id @default(autoincrement())
  title       String
  type        String
  fileUrl     String?
  createdById Int
  createdBy   User      @relation(fields: [createdById], references: [id])
  regionId    Int?
  region      Region?   @relation(fields: [regionId], references: [id])
  districtId  Int?
  district    District? @relation(fields: [districtId], references: [id])
  mahallaId   Int?
  mahalla     Mahalla?  @relation(fields: [mahallaId], references: [id])
  createdAt   DateTime  @default(now())

  @@map("reports")
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  user      User             @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@map("notifications")
}

model ImportJob {
  id          Int          @id @default(autoincrement())
  fileUrl     String
  status      ImportStatus @default(PENDING)
  totalRows   Int          @default(0)
  successRows Int          @default(0)
  failedRows  Int          @default(0)
  errorLog    String?
  createdById Int
  createdBy   User         @relation(fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())

  @@map("import_jobs")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@map("refresh_tokens")
}

model Event {
  id              Int        @id @default(autoincrement())
  title           String
  description     String
  type            EventType  @default(OTHER)
  status          EventStatus @default(DRAFT)
  startDate       DateTime
  endDate         DateTime
  location        String
  maxParticipants Int?
  imageUrl        String?
  regionId        Int?
  region          Region?    @relation(fields: [regionId], references: [id])
  districtId      Int?
  district        District?  @relation(fields: [districtId], references: [id])
  organizerId     Int
  organizer       User       @relation("EventOrganizer", fields: [organizerId], references: [id])
  participants    EventParticipant[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  @@map("events")
}

model EventParticipant {
  id           Int       @id @default(autoincrement())
  eventId      Int
  event        Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId       Int
  user         User      @relation(fields: [userId], references: [id])
  registeredAt DateTime  @default(now())
  attended     Boolean   @default(false)
  attendedAt   DateTime?
  @@unique([eventId, userId])
  @@map("event_participants")
}

model Survey {
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  status      SurveyStatus @default(DRAFT)
  createdById Int
  createdBy   User         @relation("SurveyCreator", fields: [createdById], references: [id])
  regionId    Int?
  region      Region?      @relation(fields: [regionId], references: [id])
  districtId  Int?
  district    District?    @relation(fields: [districtId], references: [id])
  startsAt    DateTime?
  endsAt      DateTime?
  questions   SurveyQuestion[]
  responses   SurveyResponse[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  @@map("surveys")
}

model SurveyQuestion {
  id         Int          @id @default(autoincrement())
  surveyId   Int
  survey     Survey       @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  text       String
  type       QuestionType @default(TEXT)
  options    Json?
  orderIndex Int
  isRequired Boolean      @default(true)
  answers    SurveyAnswer[]
  createdAt  DateTime     @default(now())
  @@map("survey_questions")
}

model SurveyResponse {
  id        Int            @id @default(autoincrement())
  surveyId  Int
  survey    Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  userId    Int
  user      User           @relation(fields: [userId], references: [id])
  answers   SurveyAnswer[]
  createdAt DateTime       @default(now())
  @@unique([surveyId, userId])
  @@map("survey_responses")
}

model SurveyAnswer {
  id         Int             @id @default(autoincrement())
  responseId Int
  response   SurveyResponse  @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId Int
  question   SurveyQuestion  @relation(fields: [questionId], references: [id])
  value      String
  @@map("survey_answers")
}

model FileRecord {
  id           Int          @id @default(autoincrement())
  originalName String
  storedName   String
  mimeType     String
  size         Int
  url          String
  category     FileCategory @default(OTHER)
  uploadedById Int
  uploadedBy   User         @relation("FileUploader", fields: [uploadedById], references: [id])
  entityType   String?
  entityId     Int?
  createdAt    DateTime     @default(now())
  @@map("file_records")
}

model SmsLog {
  id              Int       @id @default(autoincrement())
  phone           String
  message         String
  status          SmsStatus @default(PENDING)
  eskizMessageId  String?
  errorMessage    String?
  createdAt       DateTime  @default(now())
  @@map("sms_logs")
}

model EmailLog {
  id           Int         @id @default(autoincrement())
  toEmail      String
  subject      String
  body         String
  status       EmailStatus @default(PENDING)
  errorMessage String?
  createdAt    DateTime    @default(now())
  @@map("email_logs")
}
